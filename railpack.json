{
  "steps": {
    "build": {
      "commands": [
        "apt-get update",
        "apt-get install -y python3 python3-pip",
        "pip3 install --break-system-packages -r backend/requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "gunicorn --chdir backend app:app --bind 0.0.0.0:$PORT --workers 4 --timeout 120"
  }
}
